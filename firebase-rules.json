{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        ".validate": "newData.hasChildren(['email', 'createdAt', 'updatedAt'])",
        
        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[^@]+@[^@]+\\.[^@]+$/)"
        },
        
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        
        "updatedAt": {
          ".validate": "newData.isNumber()"
        },
        
        "plan": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid",
          ".validate": "newData.hasChildren(['type', 'productsLimit', 'createdAt'])",
          
          "type": {
            ".validate": "newData.val() === 'Free' || newData.val() === 'Pro' || newData.val() === 'Enterprise'"
          },
          
          "productsLimit": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          
          "createdAt": {
            ".validate": "newData.isNumber()"
          }
        },
        
        "products": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid",
          ".indexOn": ["updatedAt", "createdAt"],
          
          "$productId": {
            ".validate": "newData.hasChildren(['id', 'name', 'price', 'description', 'brand', 'imageUrl', 'stock', 'featured', 'createdAt', 'updatedAt'])",
            
            "id": {
              ".validate": "newData.isString() && newData.val() === $productId"
            },
            
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200"
            },
            
            "price": {
              ".validate": "newData.isString() && newData.val().matches(/^\\$?[0-9]+(\\.[0-9]{2})?$/)"
            },
            
            "oldPrice": {
              ".validate": "newData.isString() || !newData.exists()"
            },
            
            "description": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 2000"
            },
            
            "brand": {
              ".validate": "newData.isString() && (newData.val() === 'iPhone' || newData.val() === 'Samsung' || newData.val() === 'Xiaomi')"
            },
            
            "imageUrl": {
              ".validate": "newData.isString() && newData.val().matches(/^https?:\\/\\/.+/)"
            },
            
            "stock": {
              ".validate": "newData.val() === 'Available' || newData.val() === 'Low stock' || newData.val() === 'Out of stock'"
            },
            
            "featured": {
              ".validate": "newData.isBoolean()"
            },
            
            "createdAt": {
              ".validate": "newData.isNumber()"
            },
            
            "updatedAt": {
              ".validate": "newData.isNumber()"
            }
          }
        }
      }
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.uid == "ydasD0Te2vYPQV2NrhBfRTtkyiD3";
    }

    match /cars/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      // Let public users create bookings from checkout without forcing login.
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
